venv/
# Keep the scorecard, the spending meter, and the tournament log in the
# repo (the cloud runs need them to persist between runs); ignore
# everything else in data/ (caches, downloads, all rebuildable).
data/*
!data/ledger.csv
!data/spend.json
!data/tournament_log.csv
__pycache__/
*.pyc
.env
.superpowers/
